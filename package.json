    "@mui/material": "^7.3.2",
    "@mui/x-date-pickers": "^8.11.2",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-router": "^1.131.41",
    "axios": "^1.12.1",
    "dayjs": "^1.11.18",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.66.1",
    "react-toastify": "^11.0.5",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
